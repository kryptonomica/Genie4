<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GenieClient.Avalonia.ViewModels"
             xmlns:views="clr-namespace:GenieClient.Avalonia.Views"
             x:Class="GenieClient.Avalonia.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Dock.Avalonia.Themes.Fluent/DockFluentTheme.axaml" />
  </Application.Styles>

  <Application.DataTemplates>
    <DataTemplate DataType="{x:Type vm:GameDocumentViewModel}">
      <views:OutputPanelView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:OutputPanelViewModel}">
      <views:OutputPanelView />
    </DataTemplate>
  </Application.DataTemplates>
</Application>
